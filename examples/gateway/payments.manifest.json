{
  "version": 1,
  "use_case": "payments",
  "tools": {
    "create_payment": {
      "amount": "arguments.amount",
      "currency": "arguments.currency",
      "business_key": "result.id",
      "action": "approve"
    }
  },
  "outcomes": {
    "list_disputes": {
      "items": "result.disputes",
      "business_key": "item.payment_id",
      "status": "item.status",
      "loss": "item.amount",
      "error_statuses": ["lost"],
      "correct_statuses": ["won"],
      "source": "chargeback",
      "census": true
    }
  }
}
